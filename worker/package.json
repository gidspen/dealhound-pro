{
  "name": "dealhound-worker",
  "version": "1.0.0",
  "description": "Background job worker — polls scrape_jobs queue and invokes find-deals agent",
  "main": "worker.js",
  "scripts": {
    "start": "node worker.js",
    "group-scan": "node group-scan-runner.js",
    "union-buy-box": "node union-buy-box.js",
    "postinstall": "find node_modules/node-pty/prebuilds -name 'spawn-helper' -exec chmod +x {} + 2>/dev/null || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "dotenv": "^16.4.5",
    "node-pty": "^1.1.0",
    "resend": "^4.8.0"
  }
}
