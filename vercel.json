{
  "buildCommand": "npm run build && rm dashboard/index.html",
  "outputDirectory": ".",
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/scan-start.js": { "maxDuration": 10 },
    "api/scan-progress.js": { "maxDuration": 10 },
    "api/user-data.js": { "maxDuration": 10 },
    "api/deal-chat.js": { "maxDuration": 60 },
    "api/conversation.js": { "maxDuration": 10 },
    "api/deal-actions.js": { "maxDuration": 30 },
    "api/health.js": { "maxDuration": 5 },
    "api/create-checkout.js": { "maxDuration": 10 },
    "api/stripe-webhook.js": { "maxDuration": 10 },
    "api/free-scan-start.js": { "maxDuration": 10 },
    "api/buy-box.js": { "maxDuration": 10 },
    "api/buy-boxes.js": { "maxDuration": 10 },
    "api/waitlist.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/magic-link", "destination": "/api/scan-report?_action=magic-link" },
    { "source": "/api/deal-files", "destination": "/api/deal-actions?_route=files" },
    { "source": "/dashboard", "destination": "/dashboard-dist/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard-dist/index.html" },
    { "source": "/free-scan", "destination": "/free-scan/index.html" }
  ]
}
